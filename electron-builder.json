{
  "appId": "com.maccleaner.app",
  "productName": "MacCleaner",
  "directories": {
    "output": "out"
  },
  "files": [
    "dist/**/*",
    "dist-electron/**/*",
    "resources/**/*"
  ],
  "mac": {
    "category": "public.app-category.utilities",
    "target": ["dmg", "zip"],
    "icon": "resources/icon.icns"
  },
  "dmg": {
    "title": "MacCleaner",
    "icon": "resources/icon.icns",
    "window": {
      "width": 540,
      "height": 380
    },
    "contents": [
      { "x": 130, "y": 190, "type": "file" },
      { "x": 410, "y": 190, "type": "link", "path": "/Applications" }
    ]
  }
}
